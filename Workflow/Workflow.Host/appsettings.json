{
	"ConnectionStrings": {
		"DefaultConnection": "Server=127.0.0.1;Port=3307;Database=workflowdb;User=root;Password=;"
	},

	"Temporal": {
		"Address": "localhost:7233",
		"Namespace": "default",
		"CaCertPath": "tls-certs/ca.crt",
		"ClientCertPath": "tls-certs/client.crt",
		"ClientKeyPath": "tls-certs/client.key"
	},

	"WorkflowRegistry": [
		{
			"EntityType": "PurchaseRequest",
			"WorkflowType": "GenericApprovalWorkflow",
			"TaskQueue": "erp-purchase-request",
			"WorkflowIdPattern": "purchase-request-{entityId}"
		}
	],

	"ActivityEndpoints": {
		"PurchaseRequest": {
			"NotifyManager": {
				"BaseUrl": "http://localhost:5100",
				"Endpoint": "api/purchase-requests/{entityId}/notify-manager"
			},
			"NotifyFinance": {
				"BaseUrl": "http://localhost:5100",
				"Endpoint": "api/purchase-requests/{entityId}/notify-finance"
			},
			"NotifyHR": {
				"BaseUrl": "http://localhost:5100",
				"Endpoint": "api/purchase-requests/{entityId}/notify-hr"
			},
			"NotifyRejection": {
				"BaseUrl": "http://localhost:5100",
				"Endpoint": "api/purchase-requests/{entityId}/notify-rejection"
			},
			"CloseRequest": {
				"BaseUrl": "http://localhost:5100",
				"Endpoint": "api/purchase-requests/{entityId}/close"
			}
		}
	},

	"WorkflowSteps": {
		"PurchaseRequest": [
			{
				"ActivityKey": "PurchaseRequest:NotifyManager",
				"WaitForSignal": "ManagerDecision",
				"RejectionActivityKey": "PurchaseRequest:NotifyRejection",
				"TimeoutMinutes": "10",
      			"MaxRetries": "3"
			},
			{
				"ActivityKey": "PurchaseRequest:NotifyFinance",
				"WaitForSignal": "FinanceDecision",
				"RejectionActivityKey": "PurchaseRequest:NotifyRejection"
			},
			{
				"ActivityKey": "PurchaseRequest:NotifyHR",
				"WaitForSignal": "HrDecision",
				"RejectionActivityKey": "PurchaseRequest:NotifyRejection"
			},
			{
				"ActivityKey": "PurchaseRequest:CloseRequest"
			}
		]
	}
}
