# =========================
# 🌍 GLOBAL IGNORE RULES
# =========================

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Environment files
.env
.env.*

# =========================
# 🟣 .NET PROJECTS
# =========================

# Build output
**/bin/
**/obj/

# Visual Studio / VS Code
.vs/
.vscode/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet
*.nupkg
packages/

# =========================
# 🟢 NODE / REACT (ERP SAFE)
# =========================

**/node_modules/
**/dist/
**/build/

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# 🐳 DOCKER
# =========================

**/*.tmp
**/*.cache

# =========================
# 🔐 TEMPORAL CERTS (VERY IMPORTANT)
# =========================

temporal-certs/*
!temporal-certs/README.md
!temporal-certs/*.example

# =========================
# 🧪 OPTIONAL
# =========================

# Coverage reports
coverage/

# IDE configs (optional ignore)
.idea/